modules = ["nodejs-22", "web", "nix"]
    [agent]
expertMode = true
    stack = "BEST_EFFORT_FALLBACK"

    [nix]
    channel = "stable-25_05"

    [workflows]
    runButton = "Project"

    [[workflows.workflow]]
    name = "Project"
    mode = "parallel"
    author = "agent"

    [[workflows.workflow.tasks]]
    task = "workflow.run"
    args = "Backend API server"

    [[workflows.workflow.tasks]]
    task = "workflow.run"
    args = "Start application"

    [[workflows.workflow]]
    name = "Backend API server"
    author = "agent"

    [[workflows.workflow.tasks]]
    task = "shell.exec"
    args = "pnpm --filter @workspace/server run dev"
    waitForPort = 3001

    [workflows.workflow.metadata]
    outputType = "console"

    [[workflows.workflow]]
    name = "Start application"
    author = "agent"

    [[workflows.workflow.tasks]]
    task = "shell.exec"
    args = "pnpm --filter @workspace/bharatscan run dev"
    waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3099
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 22167
externalPort = 3002

    [deployment]
    deploymentTarget = "autoscale"
    run = ["bash", "-c", "pnpm --filter @workspace/server run start & PORT=5000 pnpm --filter @workspace/bharatscan run serve"]
    build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/server run build && pnpm --filter @workspace/bharatscan run build"]

    [userenv]

    [userenv.shared]
    BASE_PATH = "/"
    DB_DIR = "./data"
    NODE_ENV = "development"
    PORT = "5000"
    SERVER_PORT = "3001"
    