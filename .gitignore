# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# SQLite database — contains personal data, created fresh per machine
bharatscan.db
bharatscan.db-shm
bharatscan.db-wal
bharatscan.db.backup

# SQLite database files and the data/ directory — never commit these.
# The data/ directory is used in Replit and on Oracle servers.
# In Electron mode the databases live in the OS user-data folder (outside the
# project tree entirely), so no extra gitignore entry is needed there.
data/

